# ===========================================
# Backend 环境变量示例
# 使用方法：复制本文件为 backend/.env 后填写真实值
# 注意：backend/.env 已经在 .gitignore 中，不要提交到仓库
# ===========================================

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- API Keys ---
# Predict.fun API Key
#   - 在 https://predict.fun 申请
#   - 未配置时：定时任务会跳过 Predict.fun 刷新，但 Polymarket 仍会正常工作
#   - 未配置时：前端调用需要 apiKey 的路由会返回 401
PREDICT_FUN_API_KEY=your_predict_fun_api_key_here

# --- 可选：对外请求代理（企业网络/受限区域） ---
# HTTPS_PROXY=http://127.0.0.1:7890
